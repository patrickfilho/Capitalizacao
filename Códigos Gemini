# 1. Calcula a quantidade de valores únicos para todas as colunas de uma vez
# Isso usa o motor otimizado do Arrow antes de trazer pro R
contagem_unicos <- base %>%
  dplyr::summarise(dplyr::across(dplyr::everything(), dplyr::n_distinct)) %>%
  dplyr::collect()

# 2. Cria o visual de lista (Coluna na esquerda, Valor na direita)
cat("\n--- VALORES ÚNICOS POR COLUNA ---\n")

for (nome_coluna in names(contagem_unicos)) {
  # Pega o valor correspondente àquela coluna
  valor <- contagem_unicos[[nome_coluna]]
  
  # O %-40s alinha o texto à esquerda garantindo um espaçamento fixo, 
  # deixando a impressão super organizada.
  cat(sprintf("%-40s : %d\n", nome_coluna, valor))
}
